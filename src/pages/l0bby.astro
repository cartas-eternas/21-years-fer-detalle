---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allMessages = await getCollection("messages");
console.log(allMessages.length);
---

<Layout title="MAFI 21 | DEDICATORIAS">
    <script is:inline src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

    <div id="cursor-dot"></div>
    <div id="cursor-outline"></div>
    <div class="grain-overlay" aria-hidden="true"></div>

    <div id="seal-overlay">
    <div class="seal-scene">
        <div class="seal-frame">

            <p class="seal-eyebrow"></p>

            <div class="seal-candles" aria-hidden="true">
                <div class="seal-candle candle-l">
                    <div class="sc-flame"></div>
                    <div class="sc-body"></div>
                </div>
                <button id="seal-button" class="wax-seal" aria-label="">
                    <svg class="seal-ring" viewBox="0 0 200 200" aria-hidden="true">
                        <path id="sealRingPath" fill="none" d="M 100,100 m -80,0 a 80,80 0 1,1 160,0 a 80,80 0 1,1 -160,0"/>
                        <text><textPath href="#sealRingPath" startOffset="0%" textLength="502" lengthAdjust="spacingAndGlyphs"></textPath></text>
                    </svg>
                    <span class="seal-core">
                        <span class="seal-symbol"></span>
                        <span class="seal-number">21</span>
                        <span class="seal-divider"></span>
                        <span class="seal-sub-text"></span>
                    </span>
                </button>
                <div class="seal-candle candle-r">
                    <div class="sc-flame"></div>
                    <div class="sc-body"></div>
                </div>
            </div>

            <div class="seal-hint-wrap">
                <span class="hint-line"></span>
                <p class="seal-hint">TOCA PARA ABRIR</p>
                <span class="hint-line hint-line-r"></span>
            </div>

        </div>
    </div>

    <div class="seal-overlay-deco" aria-hidden="true">
        <span class="float-rune r1">✦</span>
        <span class="float-rune r2">✧</span>
        <span class="float-rune r3">✦</span>
        <span class="float-rune r4">✧</span>
        <span class="float-rune r5">✦</span>
        <span class="float-rune r6">✧</span>
    </div>
</div>
    <div class="bg-wallpaper"></div>
    <div class="bg-grid"></div>
    <div class="bg-vignette"></div>
    <div class="massive-bg-text">FER_21</div>

    <div class="tape tape-top">
        <span>FELIZ CUMPLEAÑOS MAFI &nbsp;·&nbsp; FELIZ CUMPLEAÑOS FER &nbsp;·&nbsp; FELIZ CUMPLEAÑOS MIELESITA PRECIOSA &nbsp;·&nbsp; FELIZ CUMPLEAÑOS HIJA &nbsp;·&nbsp; FELIZ CUMPLEAÑOSSSSSS ESPOSA MIA &nbsp;·&nbsp; </span>
    </div>
    <div class="tape tape-bottom">
        <span>FELIZ CUMPLEAÑOS MAFI &nbsp;·&nbsp; FELIZ CUMPLEAÑOS FER &nbsp;·&nbsp; FELIZ CUMPLEAÑOS MIELESITA PRECIOSA &nbsp;·&nbsp; FELIZ CUMPLEAÑOS HIJA &nbsp;·&nbsp; FELIZ CUMPLEAÑOSSSSSS ESPOSA MIA &nbsp;·&nbsp; </span>
    </div>

    <main class="container" id="main-content">
        <header class="header">
            <p class="header-eyebrow gsap-fade"></p>

            <div class="badge-wrapper">
                <svg class="candle-flame flame-left" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2c-2.2 3.6-6 6.4-6 10.6a6 6 0 0 0 12 0c0-4.2-3.8-7-6-10.6z"/>
                </svg>
                <svg class="rotating-badge" viewBox="0 0 100 100">
                    <path id="circlePath" fill="none" d="M 50,50 m -40,0 a 40,40 0 1,1 80,0 a 40,40 0 1,1 -80,0"/>
                    <text><textPath href="#circlePath" startOffset="0%">21 21 21 21 21 21 21 21 21 21 21 21 21 </textPath></text>
                </svg> 
                <div class="badge-center">21</div>
                <svg class="candle-flame flame-right" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2c-2.2 3.6-6 6.4-6 10.6a6 6 0 0 0 12 0c0-4.2-3.8-7-6-10.6z"/>
                </svg>
            </div>

            <h1 class="main-title">
                <span class="title-solid">Twenty One</span>
                <span class="title-outline crossed-out">Pilots</span>
                <span class="title-solid">Years</span>
            </h1>

        </header>

        <div class="grid-title gsap-fade">
            <div class="grid-title-inner">
                <h2>TUS AMIGOS, FAMILIA Y YO TE HEMOS PREPARADO ALGO <3 <span class="counter"></span></h2>
                <p class="grid-subtitle">Cada sobre guarda una dedicatoria. Ábrelos todos.</p>
            </div>
        </div>

        <div class="grid">
            {allMessages.map((message, index) => (
                <a href={`/${message.id}`} class="envelope-card gsap-card" data-index={index}>
                    <div class="env-bg-glow"></div>
                    <div class="env-back"></div>
                    <div class="env-flap-back"></div>
                    <div class="env-flap-front">
                        <div class="flap-inner-fold"></div>
                    </div>
                    <div class="env-body">
                        <div class="env-corner tl"></div>
                        <div class="env-corner tr"></div>
                        <div class="env-corner bl"></div>
                        <div class="env-corner br"></div>
                        <div class="env-postmark" aria-hidden="true">
                            <svg viewBox="0 0 60 60">
                                <circle cx="30" cy="30" r="27" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 2"/>
                                <text x="50%" y="34%" text-anchor="middle" dominant-baseline="middle" font-size="7" letter-spacing="1">PARA</text>
                                <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" font-size="7" letter-spacing="1">FER</text>
                                <text x="50%" y="70%" text-anchor="middle" dominant-baseline="middle" font-size="5.5" letter-spacing="0.5">21 AÑOS</text>
                            </svg>
                        </div>
                        <div class="env-number" aria-hidden="true">{(index + 1).toString().padStart(2, '0')}</div>
                        <div class="env-wax-seal" aria-hidden="true">
                            <div class="mini-seal-inner"><span>❧</span></div>
                        </div>
                        <div class="env-sender-label">
                            <span class="env-from-label">de</span>
                            <span class="env-sender-name">{message.data.sender}</span>
                        </div>
                        <div class="env-open-hint">
                            <span>abrir carta</span>
                            <svg viewBox="0 0 24 10" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M1 5h20M16 1l5 4-5 4"/>
                            </svg>
                        </div>
                    </div>
                    <div class="env-shine"></div>
                </a>
            ))}
        </div>

        <footer class="site-footer gsap-fade">
            <p>Hecho con cariño para celebrar a Fer.</p>
        </footer>
    </main>

<script is:inline>
    function fireConfetti() {
        const duration = 3000;
        const end = Date.now() + duration;
        const colors = ['#E50000', '#FCE300', '#FFFFFF', '#111111'];
        (function frame() {
            confetti({ particleCount: 6, angle: 60, spread: 60, origin: { x: 0, y: 0.9 }, colors });
            confetti({ particleCount: 6, angle: 120, spread: 60, origin: { x: 1, y: 0.9 }, colors });
            if (Date.now() < end) requestAnimationFrame(frame);
        }());
    }

    const dot = document.getElementById('cursor-dot');
    const outline = document.getElementById('cursor-outline');
    window.addEventListener('mousemove', (e) => {
        dot.style.left = `${e.clientX}px`;
        dot.style.top = `${e.clientY}px`;
        gsap.to(outline, { x: e.clientX - 20, y: e.clientY - 20, duration: 0.15, ease: "power2.out" });
    });

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const SEAL_KEY = 'mafi21_seal_broken';

    function revealSite(withAnimation) {
        const mainContent = document.getElementById('main-content');
        mainContent?.removeAttribute('aria-hidden');

        if (!withAnimation) {
            mainContent.style.opacity = '1';
            return;
        }

        const tl = gsap.timeline();
        tl.from(".massive-bg-text", { opacity: 0, scale: 1.2, duration: 1 })
            .from(".tape-top", { y: "-100%", duration: 0.9, ease: "power3.out" }, "-=0.7")
            .from(".tape-bottom", { y: "100%", duration: 0.9, ease: "power3.out" }, "-=0.9")
            .from(".header-eyebrow", { opacity: 0, duration: 0.5 }, "-=0.5")
            .from(".badge-wrapper", { rotate: -180, opacity: 0, scale: 0, duration: 1, ease: "back.out(1.5)" }, "-=0.4")
            .from(".main-title", { y: 50, opacity: 0, duration: 0.8, ease: "power3.out" }, "-=0.6")
            .from(".gsap-welcome", { y: 30, opacity: 0, duration: 0.6 }, "-=0.4")
            .from(".gsap-fade", { opacity: 0, duration: 0.5, stagger: 0.15 }, "-=0.2")
            .from(".gsap-card", {
                y: 60, opacity: 0, duration: 0.6, stagger: 0.1, ease: "back.out(1.2)",
                onComplete: () => setTimeout(fireConfetti, 300)
            }, "-=0.2");
    }

    function initSeal() {
        const sealButton = document.getElementById('seal-button');
        const sealOverlay = document.getElementById('seal-overlay');

        const alreadyOpened = sessionStorage.getItem(SEAL_KEY);

        if (alreadyOpened) {
            sealOverlay.style.display = 'none';
            revealSite(false);
            return;
        }

        document.getElementById('main-content')?.setAttribute('aria-hidden', 'true');

        function breakSeal() {
            if (sealButton.classList.contains('breaking')) return;
            sealButton.classList.add('breaking');
            sealButton.disabled = true;

            const waitTime = prefersReducedMotion ? 50 : 900;
            setTimeout(() => {
                gsap.to(sealOverlay, {
                    y: "-100vh",
                    duration: prefersReducedMotion ? 0.3 : 0.9,
                    ease: "power3.inOut",
                    onComplete: () => {
                        sealOverlay.style.display = 'none';
                        sessionStorage.setItem(SEAL_KEY, 'true');
                        revealSite(true);
                    }
                });
            }, waitTime);
        }

        sealButton.addEventListener('click', breakSeal);
    }

    document.addEventListener("DOMContentLoaded", initSeal);
</script>
</Layout>

<style>
    @import url('https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap');
    @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&display=swap');
    @import url('https://fonts.googleapis.com/css2?family=Bodoni+Moda:wght@400;600;700;800&display=swap');
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&display=swap');
    :global(:root) {
        --red: #D10000;
        --red-deep: #8a0000;
        --red-dim: rgba(209, 0, 0, 0.18);
        --gold: #C9A227;
        --gold-bright: #E8C468;
        --gold-pale: #f0d88a;
        --ash: #6a6a6a;
        --ash-light: #9a9a9a;
        --ink: #0a0a0a;
        --paper: #111010;
        --env-border: #5a3f10;
    }

    html, body { cursor: none; overflow-x: hidden; background: var(--ink); }

    #cursor-dot {
        width: 5px; height: 5px; background: #fff; border-radius: 50%;
        position: fixed; pointer-events: none; z-index: 9999; transform: translate(-50%, -50%);
    }
    #cursor-outline {
        width: 38px; height: 38px; border: 1.5px solid var(--red); border-radius: 50%;
        position: fixed; pointer-events: none; z-index: 9998;
    }

    .grain-overlay {
        position: fixed; inset: 0; z-index: 2; pointer-events: none; opacity: 0.06; mix-blend-mode: overlay;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    }

    #seal-overlay {
    position: fixed; inset: 0; z-index: 9000;
    background: var(--ink);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
}

.seal-scene {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: center;
}

.seal-frame {
    display: flex; flex-direction: column; align-items: center; gap: 2.8rem;
}

.seal-eyebrow {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: 0.9rem; letter-spacing: 4px;
    color: var(--ash); text-align: center;
}

.wax-seal {
    position: relative; width: 210px; height: 210px;
    border-radius: 50%;
    background: transparent;
    border: 1.5px solid var(--red);
    box-shadow: 0 0 0 8px rgba(209,0,0,0.04), 0 0 40px rgba(209,0,0,0.08);
    display: flex; align-items: center; justify-content: center;
    cursor: none; padding: 0;
    transition: box-shadow 0.4s ease, border-color 0.4s ease;
}
.wax-seal:hover:not(.breaking) {
    border-color: var(--gold);
    box-shadow: 0 0 0 8px rgba(201,162,39,0.05), 0 0 55px rgba(201,162,39,0.1);
}
.wax-seal:focus-visible { outline: 1px solid var(--gold); outline-offset: 12px; }

.seal-ring {
    position: absolute; inset: 0; width: 100%; height: 100%;
    animation: rotate 22s linear infinite;
}
.seal-ring text {
    fill: var(--ash);
    font-family: 'Space Mono', monospace; font-size: 8.5px; letter-spacing: 0.5px;
}

.seal-core {
    position: relative; z-index: 2; text-align: center;
    pointer-events: none; display: flex; flex-direction: column;
    align-items: center; line-height: 1;
}
.seal-symbol {
    display: block; font-size: 0.85rem; color: var(--ash);
    margin-bottom: 0.3rem; letter-spacing: 0;
}
.seal-number {
    display: block; font-family: 'UnifrakturMaguntia', cursive;
    font-size: 4.5rem; color: #fff; line-height: 0.9;
}
.seal-divider {
    display: block; font-size: 0.45rem; color: var(--ash);
    letter-spacing: 3px; margin: 0.25rem 0;
}
.seal-sub-text {
    display: block; font-family: 'Space Mono', monospace;
    font-size: 0.48rem; color: var(--ash);
    letter-spacing: 7px; text-transform: uppercase;
}

.wax-seal.breaking .seal-core { animation: crackShake 0.5s ease; }
.wax-seal.breaking::before,
.wax-seal.breaking::after {
    content: ''; position: absolute; inset: 0;
    border-radius: 50%;
    background: var(--ink);
    border: 1.5px solid var(--red);
}
.wax-seal.breaking::before {
    clip-path: polygon(0 0, 50% 0, 44% 58%, 22% 100%, 0 100%);
    animation: splitLeft 0.8s cubic-bezier(0.6, 0, 0.8, 1) forwards 0.2s;
}
.wax-seal.breaking::after {
    clip-path: polygon(50% 0, 100% 0, 100% 100%, 22% 100%, 44% 58%);
    animation: splitRight 0.8s cubic-bezier(0.6, 0, 0.8, 1) forwards 0.2s;
}
@keyframes crackShake {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    20% { transform: translate(-4px, 3px) rotate(-1deg); }
    40% { transform: translate(4px, -3px) rotate(1deg); }
    60% { transform: translate(-3px, -2px) rotate(-0.5deg); }
    80% { transform: translate(2px, 2px) rotate(0.5deg); }
}
@keyframes splitLeft { to { transform: translate(-80px, 60px) rotate(-22deg); opacity: 0; } }
@keyframes splitRight { to { transform: translate(80px, 60px) rotate(22deg); opacity: 0; } }

.seal-hint-wrap {
    display: flex; align-items: center; gap: 1.9rem;
}
.hint-line {
    display: block; width: 40px; height: 1px; background: rgba(106,106,106,0.3);
}
.hint-line-r { background: rgba(106,106,106,0.3); }
.seal-hint {
    font-family: 'DM Serif Display', serif; font-style: serif;
    color: var(--ash); font-size: 2.95rem; letter-spacing: 2px;
    animation: pulseHint 0.5s ease-in-out infinite;
}
@keyframes pulseHint { 0%, 100% { opacity: 0.3; } 50% { opacity: 0.75; } }

.seal-overlay-deco { position: absolute; inset: 0; pointer-events: none; }
.float-rune {
    position: absolute; color: var(--red); opacity: 0.07; font-size: 1.2rem;
    animation: runeFloat 7s ease-in-out infinite;
}
.r1 { top: 8%; left: 6%; animation-delay: 0s; font-size: 1.8rem; }
.r2 { top: 18%; right: 8%; animation-delay: 1.2s; font-size: 0.9rem; }
.r3 { bottom: 22%; left: 10%; animation-delay: 2.4s; font-size: 0.8rem; }
.r4 { bottom: 12%; right: 6%; animation-delay: 3.6s; font-size: 2rem; }
.r5 { top: 52%; left: 3%; animation-delay: 1.8s; }
.r6 { top: 38%; right: 4%; animation-delay: 3s; font-size: 0.8rem; }
@keyframes runeFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.06; }
    50% { transform: translateY(-18px) rotate(12deg); opacity: 0.13; }
}
    @keyframes rotate { 100% { transform: rotate(360deg); } }

    .bg-wallpaper {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;

    background-image:
        radial-gradient(
            circle at top,
            rgba(209,0,0,.18) 0%,
            transparent 25%
        ),

        linear-gradient(
            180deg,
            rgba(8,8,8,.45) 0%,
            rgba(8,8,8,.65) 60%,
            rgba(8,8,8,.80) 100%
        ),

        url('../public/fondo.jpg');

    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
}
    .bg-grid {
        position: fixed; top: 0; left: 0; width: 200vw; height: 200vh;
        background-image:
            linear-gradient(rgba(180, 0, 0, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(180, 0, 0, 0.05) 1px, transparent 1px);
        background-size: 60px 60px; z-index: -3;
        transform: rotate(-15deg) translateY(-50px);
        animation: scrollGrid 30s linear infinite;
    }
    @keyframes scrollGrid { 100% { transform: rotate(-15deg) translateY(0px) translateX(-60px); } }
    .bg-vignette {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        background: radial-gradient(circle, transparent 40%, rgba(4, 4, 4, 1) 92%);
        z-index: -2; pointer-events: none;
    }
    .massive-bg-text {
        position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
        font-family: 'UnifrakturMaguntia', cursive;
        font-size: clamp(8rem, 22vw, 26rem);
        color: transparent; -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.025);
        z-index: -1; pointer-events: none; white-space: nowrap; user-select: none;
    }

    .tape {
        position: fixed; left: 0; width: 100%; z-index: 40;
        color: rgba(0,0,0,0.85); font-family: 'Space Mono', monospace;
        font-size: 0.78rem; letter-spacing: 2px;
        padding: 0.55rem 0; overflow: hidden; white-space: nowrap;
        background: var(--red);
        border: none;
    }
    .tape-top { top: 0; box-shadow: 0 2px 20px rgba(180,0,0,0.4); }
    .tape-bottom { bottom: 0; box-shadow: 0 -2px 20px rgba(180,0,0,0.4); }
    .tape span { display: inline-block; padding-left: 100%; animation: marqueeTape 32s linear infinite; }
    .tape-bottom span { animation-direction: reverse; }
    @keyframes marqueeTape { 100% { transform: translateX(-100%); } }

    .container {
        max-width: 1280px; margin: 0 auto;
        padding: 7rem 2.5rem 6rem 2.5rem;
        position: relative; z-index: 10; overflow: hidden;
    }

    .header {
        display: flex; flex-direction: column; align-items: center;
        margin-bottom: 7rem; position: relative;
    }

    .header-eyebrow {
        font-family: 'Space Mono', monospace; font-size: 0.72rem;
        letter-spacing: 5px; color: var(--ash); margin-bottom: 3.5rem;
        text-align: center; text-transform: lowercase;
    }

    .badge-wrapper {
        position: relative; width: 200px; height: 200px; margin-bottom: 3.5rem;
    }
    .badge-wrapper::before {
        content: ''; position: absolute; top: -28px; left: 50%;
        transform: translateX(-50%);
        width: 260px; height: 300px;
        border: 1px solid rgba(201, 162, 39, 0.18);
        border-radius: 130px 130px 6px 6px; z-index: -1;
    }
    .rotating-badge {
        width: 100%; height: 100%; animation: rotate 70s linear infinite;
    }
    .rotating-badge text {
        fill: var(--red); font-family: 'Space Mono', monospace;
        font-size: 8.5px; letter-spacing: 1px;
    }
    .badge-center {
        position: absolute; top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        font-family: 'UnifrakturMaguntia', cursive;
        font-size: 5rem; color: #fff; line-height: 1;
        text-shadow: 0 0 30px rgba(209,0,0,0.3);
    }

    .candle-flame {
        position: absolute; top: 10%; width: 16px; height: 24px;
        fill: var(--gold-bright);
        filter: drop-shadow(0 0 5px var(--gold));
        animation: flicker 1.8s ease-in-out infinite;
    }
    .flame-left { left: -32px; }
    .flame-right { right: -32px; animation-delay: 0.4s; transform: scaleX(-1); }
    @keyframes flicker {
        0%, 100% { transform: scaleY(1) scaleX(1); opacity: 1; }
        25% { transform: scaleY(1.1) scaleX(0.95); opacity: 0.85; }
        50% { transform: scaleY(0.92) scaleX(1.04); opacity: 1; }
        75% { transform: scaleY(1.04) scaleX(0.94); opacity: 0.9; }
    }

    .main-title {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(3.2rem, 11vw, 8rem);
        line-height: 1.05; text-align: center; margin-bottom: 3.5rem;
        display: flex; flex-direction: column; gap: 0.1rem;
    }
    .title-solid {
        color: #fff;
        text-shadow: 0 0 40px rgba(209,0,0,0.2), 3px 3px 0 rgba(0,0,0,0.8);
    }
    .title-outline {
        color: transparent; -webkit-text-stroke: 1.5px var(--red);
        position: relative; display: inline-block;
    }
    .crossed-out {
        text-decoration: line-through;
        text-decoration-color: var(--gold);
        text-decoration-thickness: 4px;
    }

    .welcome-box {
        background: rgba(209, 0, 0, 0.04);
