---
import Layout from "../layouts/Layout.astro";
---

<Layout title="ACCESS DENIED">

<div class="bg-wallpaper"></div>
<div class="grain"></div>
<div class="vignette"></div>

<main class="container">

    <div class="background-word">
        BREACH
    </div>

    <div class="panel">

        <div class="lock">
            🔒
        </div>

        <p class="small">
            ARCHIVO PROTEGIDO
        </p>

        <h1>
            ACCESS DENIED
        </h1>

        <div class="divider"></div>

        <p class="description">
            Este directorio permanece sellado.<br>
            Solo quienes poseen la ruta correcta podrán acceder a las dedicatorias.
        </p>

        <div class="terminal">
            ERROR 401 // BREACH NOT AUTHORIZED
        </div>

    </div>

</main>

</Layout>

<style>

@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Serif+Display&display=swap');

:global(body){
    margin:0;
    background:#070707;
    overflow:hidden;
}

.bg-wallpaper{
    position:fixed;
    inset:0;
    background:
        linear-gradient(rgba(5,5,5,.82),rgba(5,5,5,.82)),
        url("/fondo.jpg");
    background-size:cover;
    background-position:center;
}

.grain{
    position:fixed;
    inset:0;
    opacity:.05;
    pointer-events:none;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
}

.vignette{
    position:fixed;
    inset:0;
    background:radial-gradient(circle,transparent 40%,black 95%);
}

.container{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    position:relative;
}

.background-word{
    position:absolute;
    font-size:min(24vw,260px);
    color:transparent;
    -webkit-text-stroke:1px rgba(255,255,255,.03);
    letter-spacing:12px;
    user-select:none;
}

.panel{
    width:min(620px,90%);
    padding:60px;
    text-align:center;
    border:1px solid rgba(201,162,39,.25);
    background:rgba(15,15,15,.88);
    backdrop-filter:blur(8px);
    box-shadow:0 0 50px rgba(0,0,0,.8);
}

.lock{
    font-size:60px;
    margin-bottom:20px;
}

.small{
    color:#8f8f8f;
    letter-spacing:6px;
    font-family:"Space Mono";
    font-size:.8rem;
}

h1{
    margin:15px 0;
    color:#ffffff;
    font-family:"DM Serif Display";
    font-size:clamp(2.5rem,6vw,4.2rem);
    letter-spacing:2px;
}

.divider{
    width:70px;
    height:2px;
    background:#C9A227;
    margin:30px auto;
}

.description{
    color:#bdbdbd;
    line-height:1.8;
    font-family:"Space Mono";
}

.terminal{
    margin-top:40px;
    color:#C1121F;
    border:1px solid rgba(193,18,31,.4);
    padding:14px;
    font-family:"Space Mono";
    letter-spacing:2px;
    background:rgba(193,18,31,.05);
}

</style>