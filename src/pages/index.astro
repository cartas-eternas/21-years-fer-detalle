---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ACCESO RESTRINGIDO">
    <main class="container">
        <div class="hero">
            <div class="lock-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
            </div>
            
            <h1>ACCESO RESTRINGIDO</h1>
            <p>Directorio raíz bloqueado. Se requiere la ruta exacta de su invitación para acceder a los archivos.</p>
            
            <div class="error-box">
                <p class="status-code">[ ERROR 401 : BRECHA NO AUTORIZADA ]</p>
            </div>
        </div>
    </main>
</Layout>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@500;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap');

    .container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        text-align: center;
        padding: 2rem;
        background: #050505;
        font-family: 'Space Mono', monospace;
        color: #EAE0D5;
    }
    
    .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: 500px;
    }
    
    .lock-icon {
        color: #C1121F;
        width: 60px;
        height: 60px;
        margin-bottom: 2rem;
    }
    
    .lock-icon svg {
        width: 100%;
        height: 100%;
    }
    
    .hero h1 {
        font-family: 'Oswald', sans-serif;
        font-size: clamp(2.5rem, 6vw, 4rem);
        margin: 0 0 1.5rem 0;
        color: #C1121F;
        letter-spacing: 2px;
        line-height: 1.1;
    }
    
    .hero p {
        font-size: 1rem;
        color: #7a7a7a;
        margin: 0 0 3rem 0;
        line-height: 1.6;
    }
    
    .error-box {
        border: 1px solid #C1121F;
        padding: 1rem 2rem;
        background: rgba(193, 18, 31, 0.05);
        box-shadow: 0 0 20px rgba(193, 18, 31, 0.1);