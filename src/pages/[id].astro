---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
    const messages = await getCollection('messages');
    return messages.map(message => ({
        params: { id: message.id },
        props: { message },
    }));
}

const { message } = Astro.props;
const { Content } = await render(message);

function getVideoEmbedUrl(url) {
    if (!url) return null;
    try {
        const urlObj = new URL(url);
        
        if (urlObj.hostname.includes('youtube.com') || urlObj.hostname === 'youtu.be') {
            let videoId = urlObj.searchParams.get('v') || urlObj.pathname.replace('/', '');
            return `https://www.youtube.com/embed/${videoId}`;
        }
        
        if (urlObj.hostname.includes('vimeo.com')) {
            let videoId = urlObj.pathname.split('/')[1];
            return `https://player.vimeo.com/video/${videoId}`;
        }

        if (urlObj.hostname.includes('drive.google.com')) {
            const match = url.match(/\/d\/([a-zA-Z0-9_-]+)/);
            if (match && match[1]) {
                return `https://drive.google.com/file/d/${match[1]}/preview`;
            }
        }
    } catch (e) {
        return null;
    }
    return url;
}

const embedUrl = message.data.type === 'video' ? getVideoEmbedUrl(message.data.videoUrl) : null;
---

<Layout title={`Para Fer - De: ${message.data.sender}`}>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

    <div id="cursor-dot"></div>
    <div id="cursor-outline"></div>
    <div class="grain-overlay" aria-hidden="true"></div>

    <div class="bg-wallpaper"></div>
    <div class="bg-vignette"></div>

    <main class="container">
        
        <article class="letter-card fade-in">
            <div class="card-corners"></div>
            
            <div class="card-header">
                <h2>DE: <span class="sender-name">{message.data.sender}</span></h2>
                <div class="header-divider"></div>
            </div>
            
            <div class="card-body">
                {message.data.type === 'video' && message.data.videoUrl && (
                    <div class="video-wrapper">
                        {message.data.videoUrl.endsWith('.mp4') ? (
                            <video controls class="local-video">
                                <source src={message.data.videoUrl} type="video/mp4" />
                            </video>
                        ) : (
                            <iframe 
                                src={embedUrl} 
                                frameborder="0" 
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                allowfullscreen>
                            </iframe>
                        )}
                    </div>
                )}

                {message.data.type === 'image' && message.data.imageUrls && message.data.imageUrls.length > 0 && (
                    <div class="gallery-wrapper">
                        {message.data.imageUrls.map((url, index) => (
                            <div class="image-wrapper">
                                <img src={url} alt={`Imagen adjunta de ${message.data.sender} - ${index + 1}`} />
                            </div>
                        ))}
                    </div>
                )}

                <div class="prose-content">
                    <Content />
                </div>
            </div>
        </article>
    </main>

    <script is:inline>
        const dot = document.getElementById('cursor-dot');
        const outline = document.getElementById('cursor-outline');
        window.addEventListener('mousemove', (e) => {
            dot.style.left = `${e.clientX}px`; dot.style.top = `${e.clientY}px`;
            gsap.to(outline, { x: e.clientX - 20, y: e.clientY - 20, duration: 0.15, ease: "power2.out" });
        });

        document.addEventListener("DOMContentLoaded", () => {
            gsap.from(".fade-in", { y: 40, opacity: 0, duration: 1, ease: "power3.out", delay: 0.2 });
            gsap.from(".back-button", { x: -20, opacity: 0, duration: 0.8, ease: "power2.out" });
        });
    </script>
</Layout>

<style>
    :global(:root) {
        --gold: #C9A227;
        --gold-bright: #E8C468;
        --wine: #4a0404;
        --wine-deep: #2a0000;
        --ash: #7a7a7a;
    }

    @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Oswald:wght@400;600&display=swap');

    html, body { cursor: none; overflow-x: hidden; }

    #cursor-dot {
        width: 6px; height: 6px; background-color: #fff; border-radius: 50%;
        position: fixed; pointer-events: none; z-index: 9999; transform: translate(-50%, -50%);
    }
    #cursor-outline {
        width: 40px; height: 40px; border: 2px solid var(--gold); border-radius: 50%;
        position: fixed; pointer-events: none; z-index: 9998;
    }

    .grain-overlay {
        position: fixed; inset: 0; z-index: 2; pointer-events: none; opacity: 0.05; mix-blend-mode: overlay;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    }

    .bg-wallpaper {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        background-image: linear-gradient(rgba(10, 10, 10, 0.85), rgba(10, 10, 10, 0.85)), url('/fondo.jpg');
        background-size: cover; background-position: center;
        z-index: -4; pointer-events: none;
    }

    .bg-vignette {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        background: radial-gradient(circle, transparent 50%, rgba(5, 5, 5, 1) 95%);
        box-shadow: inset 0 0 100px rgba(229, 0, 0, 0.15); z-index: -2; pointer-events: none;
    }

    .container {
        max-width: 850px; margin: 0 auto; padding: 4rem 2rem 8rem 2rem; position: relative; z-index: 10;
    }

    .back-button {
        display: inline-flex; align-items: center; gap: 0.5rem; color: var(--gold);
        font-family: 'Oswald', sans-serif; font-size: 0.9rem; letter-spacing: 2px;
        margin-bottom: 3rem; transition: all 0.3s ease; text-decoration: none;
    }
    .back-button svg { width: 18px; height: 18px; transition: transform 0.3s ease; }
    .back-button:hover { color: var(--gold-bright); text-shadow: 0 0 8px rgba(201, 162, 39, 0.4); }
    .back-button:hover svg { transform: translateX(-4px); }

    .letter-card {
        background: radial-gradient(circle at top right, rgba(201, 162, 39, 0.08), transparent 80%), rgba(15, 15, 15, 0.95);
        border: 1px solid var(--gold); border-radius: 12px; position: relative;
        box-shadow: 0 20px 50px rgba(0,0,0,0.8), inset 0 0 20px rgba(201, 162, 39, 0.03);
        padding: 4rem; overflow: hidden;
    }

    .card-corners::before, .card-corners::after {
        content: ''; position: absolute; width: 20px; height: 20px; border: 2px solid var(--gold); opacity: 0.5;
    }
    .card-corners::before { top: 15px; left: 15px; border-right: none; border-bottom: none; }
    .card-corners::after { bottom: 15px; right: 15px; border-left: none; border-top: none; }

    .card-header { text-align: center; margin-bottom: 3rem; }
    .card-header h2 {
        font-family: 'Oswald', sans-serif; font-size: 1.2rem; color: var(--ash);
        letter-spacing: 4px; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;
    }
    .sender-name {
        font-family: 'Cinzel Decorative', serif; font-size: 3rem; color: var(--gold-bright);
        letter-spacing: 2px; text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
    }
    .header-divider { width: 60px; height: 2px; background: var(--gold); margin: 2rem auto 0 auto; opacity: 0.5; }

    .card-body { position: relative; z-index: 2; }

    .video-wrapper {
        position: relative; padding-bottom: 56.25%; height: 0; margin-bottom: 3rem;
        border: 2px solid var(--gold); border-radius: 8px; background: #000;
        box-shadow: 0 10px 30px rgba(0,0,0,0.6); overflow: hidden;
    }
    .video-wrapper iframe, .local-video {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;
    }

    .gallery-wrapper {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .image-wrapper {
        border: 2px solid var(--gold); border-radius: 8px;
        background: #000; box-shadow: 0 10px 30px rgba(0,0,0,0.6); overflow: hidden;
        display: flex; justify-content: center; align-items: center;
    }
    
    .image-wrapper img {
        width: 100%; height: auto; display: block; object-fit: contain;
    }

    .prose-content :global(p) {
        font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; line-height: 1.8;
        color: #EAE0D5; margin-bottom: 1.5rem; text-align: justify;
    }
    .prose-content :global(strong) { color: var(--gold-bright); font-weight: 600; }
    .prose-content :global(em) { color: var(--gold); font-style: italic; }
    .prose-content :global(h1), .prose-content :global(h2), .prose-content :global(h3) {
        font-family: 'Cinzel Decorative', serif; color: var(--gold-bright);
        margin-top: 2.5rem; margin-bottom: 1rem;
    }

    @media (max-width: 768px) {
        .container { padding: 2rem 1rem 4rem 1rem; }
        .letter-card { padding: 2.5rem 1.5rem; }
        .sender-name { font-size: 2.2rem; }
        .prose-content :global(p) { font-size: 1.2rem; text-align: left; }
    }
</style>