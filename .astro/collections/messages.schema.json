{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "sender": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "text",
        "video",
        "image"
      ]
    },
    "videoUrl": {
      "type": "string"
    },
    "imageUrls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "isAngel": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "sender",
    "type"
  ]
}